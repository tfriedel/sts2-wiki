---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const isDeprecated = (item: { data: { class_name: string } }) =>
  item.data.class_name.includes('Deprecated');

const cards = await getCollection('cards');
const relics = await getCollection('relics');
const potions = (await getCollection('potions')).filter(p => !isDeprecated(p));
const powers = await getCollection('powers');
const testMonsters = new Set(['BigDummy', 'MultiAttackMoveMonster', 'OneHpMonster', 'SingleAttackMoveMonster', 'TenHpMonster', 'TestSubject', 'TheAdversaryMkOne', 'TheAdversaryMkTwo', 'TheAdversaryMkThree']);
const monsters = (await getCollection('monsters')).filter(m => !testMonsters.has(m.data.class_name));
const encounters = (await getCollection('encounters')).filter(e => !isDeprecated(e));
const events = (await getCollection('events')).filter(e => !isDeprecated(e));
const ancients = await getCollection('ancients');
const epochs = await getCollection('epochs');

const charCollection = await getCollection('characters');

const sections = [
  { href: 'characters/', label: 'Characters', count: charCollection.length, desc: 'Playable characters with stats and starting decks' },
  { href: 'cards/', label: 'Cards', count: cards.length, desc: 'All playable cards by character, type, and rarity' },
  { href: 'relics/', label: 'Relics', count: relics.length, desc: 'Passive items with icons and descriptions' },
  { href: 'potions/', label: 'Potions', count: potions.length, desc: 'Consumable items with effects' },
  { href: 'powers/', label: 'Effects', count: powers.length, desc: 'Buffs and debuffs applied in combat' },
  { href: 'enchantments/', label: 'Enchantments', count: null, desc: 'Permanent card modifications from events and relics' },
  { href: 'monsters/', label: 'Monsters', count: monsters.length, desc: 'Enemies and companions with movesets' },
  { href: 'acts/', label: 'Acts', count: 4, desc: 'Game areas with encounters, events, and bosses' },
  { href: 'encounters/', label: 'Encounters', count: encounters.length, desc: 'Combat encounters across all acts' },
  { href: 'events/', label: 'Events', count: events.length, desc: 'Random events with choices' },
  { href: 'ancients/', label: 'Ancients', count: ancients.length, desc: 'Ancient lords with relic offerings' },
  { href: 'epochs/', label: 'Epochs', count: epochs.length, desc: 'Unlock progression milestones' },
  { href: 'ascensions/', label: 'Ascensions', count: 10, desc: 'Difficulty modifiers that stack as you climb' },
  { href: 'mechanics', label: 'Mechanics', count: null, desc: 'How rewards, shops, combat, and other systems work' },
  { href: 'patches/', label: 'Patch Notes', count: null, desc: 'Balance changes between game versions' },
];

const characters = ['Ironclad', 'Silent', 'Defect', 'Necrobinder', 'Regent'];
const charCounts = characters.map(ch => ({
  name: ch,
  cards: cards.filter(c => c.data.character === ch).length,
}));
---

<BaseLayout title="Home">
  <div class="hero">
    <h1>Slay the Spire 2</h1>
    <p class="tagline">
      Unofficial reference wiki — {cards.length} cards, {relics.length} relics,
      {monsters.length} monsters, and more from game data {import.meta.env.PUBLIC_STS2_VERSION || 'v0.103.2'}
    </p>
  </div>

  <div class="home-grid">
    {sections.map(s => (
      <a href={`${import.meta.env.BASE_URL}${s.href}`} class="home-card">
        <h3>{s.label}</h3>
        {s.count != null && <div class="count">{s.count}</div>}
        <p class="card-meta" style="margin-top: 0.5rem;">{s.desc}</p>
      </a>
    ))}
  </div>

  <h2 style="margin-top: 3rem; text-align: center;">Characters</h2>
  <div style="display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap; margin-top: 1rem;">
    {charCounts.map(ch => (
      <a href={`${import.meta.env.BASE_URL}characters/${ch.name.toLowerCase()}/`}
         class="card-entry"
         style="text-align: center; min-width: 130px; padding: 1rem;">
        <img src={`${import.meta.env.BASE_URL}images/characters/character_icon_${ch.name.toLowerCase()}.png`}
             alt={ch.name}
             style="width: 48px; height: 48px; object-fit: contain; margin-bottom: 0.5rem;"
             onerror="this.style.display='none'" />
        <h3 class={`char-${ch.name.toLowerCase()}`}>{ch.name}</h3>
        <div class="card-meta">{ch.cards} cards</div>
      </a>
    ))}
  </div>
</BaseLayout>
